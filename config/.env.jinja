


# --------------------------------- Superset --------------------------------- #
# Variables that are predefined by superset. Needed as env vars on launch.

SUPERSET_SECRET_KEY={{ superset_secret_key }}
# randomly generate this key via 'openssl rand -base64 42'
SUPERSET_ADMIN={{ superset_admin }}
SUPERSET_PASSWORD={{ superset_password }}
SUPERSET_ADMIN_EMAIL={{ superset_admin_email }}
SUPERSET_LOAD_EXAMPLES=no

# Gunicorn processes and threads
FLASK_ENV=production
SERVER_WORKER_AMOUNT=4
SERVER_THREADS_AMOUNT=30

# Mapbox integration (map visualizations in superset require a mapbox token)
MAPBOX_API_KEY=

NO_PROXY=superset-app,superset-postgres,superset-redis,superset-init,superset-worker,superset-beat,localhost,127.0.0.1
# Needed for intra-container communication.
# e.g. so that superset commands (which should work offline, such as local email reports)
# work, even when the whole stack stis behind a proxy.

# ---------------------------- superset_config.py ---------------------------- #
# Variables that are picked up in our example superset_config.py

# Mailing
SMTP_USER={{ smtp_user }}
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_PASSWORD={{ smtp_password }}

# The following vars are used in superset_config, but are shared with other services
# and define further below
# DOMAIN
# AUTH_TYPE
# USE_ROLE_BASED_REDIRECTS
# POSTGRES_*
# REDIS_*

# --------------------------------- Keycloak --------------------------------- #

# Authentication.
# This is a superset variable, used in our example superset_config.py.
AUTH_TYPE=AUTH_DB # set to AUTH_OAUTH to enable Keycloak SSO

# When using keycloak, you will likely have your own CA.
# In this case, we need to tell flask and apt to trust it.
# The two vars are the standard ones used by flask and apt.
REQUESTS_CA_BUNDLE=/app/superset/auth_keycloak/custom-ca.crt
SSL_CERT_FILE=/app/superset/auth_keycloak/custom-ca.crt
USE_ROLE_BASED_REDIRECTS="false"

# ------------------------------ Superset Helper ----------------------------- #

# Postgres
POSTGRES_DB=superset   # these should not be changed, there is a bug with superset db init.
POSTGRES_USER=superset # these should not be changed, there is a bug with superset db init.
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_HOST=superset-postgres
POSTGRES_PORT=5432
# Note on ports:
# Container-to container communication uses the native ports (not the ones exposed to the host!)
# The port variables only affect the port mapping to the host machine.

# Redis Configuration
REDIS_HOST=superset-redis
REDIS_PORT=6379
REDIS_PASSWORD={{ redis_password }}
REDIS_SSL=false

# ----------------------------------- Caddy ---------------------------------- #
# if using letsencrypt with traefik
# If you do not use localhost here, you might have to edit /etc/hosts.
DOMAIN_NAME={{ domain_name }}
DOMAIN=https://{{ domain_name }}

# Reverse proxy TLS mode (used by docker-compose.caddy.yml)
# - TLS_MODE=acme       => public certificate via ACME (Let's Encrypt), ACME_EMAIL must be set!
# - TLS_MODE=selfsigned => internal PKI (coasti CA root + intermediate)
# - TLS_MODE=internal   => use a custom certificate/key (mounted into the caddy container)
ACME_EMAIL={{ superset_admin_email }}
TLS_MODE=selfsigned

# Custom certificate mode settings (TLS_MODE=internal)
# The docker-compose.caddy.yml mounts ./certs -> /etc/caddy/certs (read-only)
TLS_CERT_FILE=/etc/caddy/certs/fullchain.pem
TLS_KEY_FILE=/etc/caddy/certs/privkey.pem


