# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
!*.example.tfvars
*.tfvars.json

# Environment files
*.env
.env.test
*.auto.tfvars

# certs
*.crt
*.key
*.pfx
*.pem


# Terraform lock file and states
.terraform.lock.hcl
.terraform/
*.tfstate
*.tfstate.backup

/data/**
!/data/.gitkeep

/backups/**
!/backups/.gitkeep

/logs/**
!/logs/.gitkeep

# keycloak
keycloak_clients.yml
*.crt

# will be created for users via templating
# exclude when working on superset stack, but we want to _include_ them in deployments
docker-compose.yml
superset_config.py
install_answers.yml
