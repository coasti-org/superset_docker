{# This gitignore is the one that gets deployed when installing this template
via copier or coasti #}

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
!*.example.tfvars
*.tfvars.json

# Environment files
*.env
.env.test
*.auto.tfvars

# certs
*.crt
*.key
*.pfx
*.pem

# Terraform lock file and states
.terraform.lock.hcl
.terraform/
*.tfstate
*.tfstate.backup

/data/**
/logs/**

# keycloak
keycloak_clients.yml
*.crt

# translations
translations/*
!translations/translations.zip
!translations/README.md
